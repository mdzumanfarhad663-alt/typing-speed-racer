# Postgres (Vercel Postgres / Neon)
POSTGRES_URL=postgres://user:pass@host/db?sslmode=require

# JWT signing secret (256+ bits, random)
JWT_SECRET=replace-with-long-random-string

# Seeded admin (single user). Generate hash with: npm run hash -- 'yourpassword'
# IMPORTANT: in this .env file you MUST backslash-escape every $ in the hash
# (Next.js dotenv expansion treats $XX as a variable). Example:
#   raw hash: $2a$10$abcd...xyz
#   in .env : \$2a\$10\$abcd...xyz
# On Vercel's env-var UI, paste the raw hash (no backslashes needed there).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=\$2a\$10\$replaceWithBcryptHash
